{
  "name": "runway-codex-control-tower",
  "description": "A code-scope contract for parallel Codex agents: declare before code, prove the Git diff after.",
  "private": true,
  "version": "1.1.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "node --test tests/runway-core.test.mjs tests/runway-cli.test.mjs fixtures/parcel-ops/tests/checkout.test.mjs fixtures/parcel-ops/tests/quote.test.mjs fixtures/parcel-ops/tests/tax.test.mjs",
    "runway": "node bin/runway.mjs",
    "package:demo": "vite build --outDir demo",
    "demo": "node bin/demo-server.mjs"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  }
}
